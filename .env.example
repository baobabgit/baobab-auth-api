# Copiez ce fichier en `.env` et renseignez vos valeurs.
# `.env` est gitignoré : n'y mettez jamais de secret dans le dépôt.

# --- baobab-auth-api (préfixe AUTH_API_) ---
AUTH_API_APP_NAME=baobab-auth-api
AUTH_API_APP_ENV=development
AUTH_API_LOG_LEVEL=INFO
# AUTH_API_CORS_ORIGINS=["http://localhost:3000"]

# --- baobab-auth-database (préfixe AUTH_DB_) ---
AUTH_DB_DATABASE_URL=sqlite:///./baobab_auth.db
AUTH_DB_ECHO_SQL=false
AUTH_DB_POOL_SIZE=5
AUTH_DB_MAX_OVERFLOW=10

# --- baobab-auth-security (préfixe BAOBAB_SECURITY_) ---
# BAOBAB_SECURITY_ISSUER=https://auth.example.com
# BAOBAB_SECURITY_AUDIENCE=baobab-auth-api
BAOBAB_SECURITY_ACCESS_TTL_SECONDS=900
BAOBAB_SECURITY_REFRESH_TTL_SECONDS=1209600
